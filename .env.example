# 当前运行环境：development / test / production
APP_ENV=development

# Django 密钥：本文件只放示例值，真实值必须写入本地 .env
DJANGO_SECRET_KEY=change-me-in-local-env

# Django 调试开关：生产环境必须为 false
DJANGO_DEBUG=false

# 允许访问的主机，多个值用逗号分隔
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL 主机
MYSQL_HOST=127.0.0.1

# MySQL 端口
MYSQL_PORT=3306

# MySQL 数据库名
MYSQL_DATABASE=the_cypto

# MySQL 用户名
MYSQL_USER=the_cypto

# MySQL 密码：真实密码不得提交
MYSQL_PASSWORD=change-me

# Redis 连接地址：用于缓存、Celery broker 和短期状态
REDIS_URL=redis://127.0.0.1:6379/0

# Celery broker 地址
CELERY_BROKER_URL=redis://127.0.0.1:6379/1

# Celery result backend 地址
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# 当前交易所硬配置
ACTIVE_EXCHANGE=Binance

# 当前交易市场类型硬配置：USDS-M 或 COIN-M
ACTIVE_MARKET_TYPE=USDS-M

# 当前账户域硬配置：用于区分账户身份
ACTIVE_ACCOUNT_DOMAIN=default

# 当前交易品种硬配置
ACTIVE_SYMBOL=BTCUSDT

# 部署级真实交易硬权限：默认必须为 false
DEPLOYMENT_REAL_TRADING_ENABLED=false

# 是否允许真实外部服务适配器：默认关闭，测试和本地开发不得开启
ALLOW_REAL_EXTERNAL_SERVICES=false

# 行情采集交易所：P0 固定为 binance
DATA_COLLECTION_EXCHANGE=binance

# 行情采集市场类型：P0 固定为 Binance USDS-M Futures
DATA_COLLECTION_MARKET_TYPE=usds_m_futures

# 行情采集品种：P0 固定为 BTCUSDT
DATA_COLLECTION_SYMBOL=BTCUSDT

# 行情采集周期：P0 只允许 4h 和 1d
DATA_COLLECTION_TIMEFRAMES=4h,1d

# DataCollection 默认 4h 回看数量
DATA_COLLECTION_4H_LOOKBACK_COUNT=10

# DataCollection 默认 1d 回看数量
DATA_COLLECTION_1D_LOOKBACK_COUNT=5

# DataBackfill 单次 Binance Kline 请求 limit 上限
DATA_BACKFILL_KLINE_PAGE_LIMIT=1000

# DataBackfill 单次运行最大分页数
DATA_BACKFILL_MAX_PAGES_PER_RUN=10

# DataBackfill 单次运行最大 Kline 数量
DATA_BACKFILL_MAX_BARS_PER_RUN=5000

# MarketSnapshot 4h 窗口默认回看数量
MARKET_SNAPSHOT_4H_LOOKBACK_COUNT=500

# MarketSnapshot 1d 窗口默认回看数量
MARKET_SNAPSHOT_1D_LOOKBACK_COUNT=365

# FeatureSet 输出合同版本
FEATURE_SCHEMA_VERSION=1.0

# AtomicSignalSet / AtomicSignalValue 输出合同版本
SIGNAL_SCHEMA_VERSION=1.0

# AtomicSignal 失败比例阻断阈值；当前流程验证阶段暂定为 0.3
ATOMIC_SIGNAL_FAILURE_BLOCK_RATIO=0.3

# DomainSignal / MarketRegime / StrategyRouting / StrategySignal 输出合同版本
DOMAIN_SIGNAL_SCHEMA_VERSION=1.0
MARKET_REGIME_SCHEMA_VERSION=1.0
STRATEGY_ROUTE_SCHEMA_VERSION=1.0
STRATEGY_SIGNAL_SCHEMA_VERSION=1.0

# StrategySignalQuality 技术边界配置：不选择 RuleSet，不改变质量放行规则
STRATEGY_SIGNAL_QUALITY_IDEMPOTENCY_LOCK_TTL_SECONDS=60
STRATEGY_SIGNAL_QUALITY_MAX_CHECK_COUNT=100
STRATEGY_SIGNAL_QUALITY_MAX_EXECUTION_SECONDS=10

# DecisionSnapshot 技术边界配置：不选择 DecisionPolicyDefinition，不改变目标仓位公式
DECISION_SNAPSHOT_SCHEMA_VERSION=1.0
DECISION_SNAPSHOT_IDEMPOTENCY_LOCK_TTL_SECONDS=60
DECISION_SNAPSHOT_MAX_EXECUTION_SECONDS=10

# Binance Gateway 总开关：默认关闭，避免测试或本地误连外部服务
BINANCE_GATEWAY_ENABLED=false

# Binance 公共行情能力开关：真实采集或价格查询前必须显式开启
BINANCE_PUBLIC_DATA_ENABLED=false

# Binance 账户只读能力开关：真实账户快照同步前必须显式开启
BINANCE_ACCOUNT_READ_ENABLED=false

# Binance 订单提交能力开关：默认关闭；订单执行阶段再启用
BINANCE_ORDER_SUBMISSION_ENABLED=false

# Binance 订单状态查询能力开关：默认关闭；订单追踪阶段再启用
BINANCE_ORDER_STATUS_QUERY_ENABLED=false

# Binance 成交查询能力开关：默认关闭；成交同步阶段再启用
BINANCE_FILL_QUERY_ENABLED=false

# Binance REST base URL 兼容旧配置；公共行情默认使用 USDS-M base URL
BINANCE_BASE_URL=https://fapi.binance.com

# Binance USDS-M Futures REST base URL
BINANCE_USDS_M_BASE_URL=https://fapi.binance.com

# Binance COIN-M Futures REST base URL
BINANCE_COIN_M_BASE_URL=https://dapi.binance.com

# Binance USDS-M 只读 API key：真实值不得提交
BINANCE_USDS_M_READ_API_KEY=

# Binance USDS-M 只读 API secret：真实值不得提交
BINANCE_USDS_M_READ_API_SECRET=

# Binance COIN-M 只读 API key：真实值不得提交
BINANCE_COIN_M_READ_API_KEY=

# Binance COIN-M 只读 API secret：真实值不得提交
BINANCE_COIN_M_READ_API_SECRET=

# Binance USDS-M 交易 API key：真实值不得提交；本阶段代码不会读取
BINANCE_USDS_M_TRADE_API_KEY=

# Binance USDS-M 交易 API secret：真实值不得提交；本阶段代码不会读取
BINANCE_USDS_M_TRADE_API_SECRET=

# Binance COIN-M 交易 API key：真实值不得提交；本阶段代码不会读取
BINANCE_COIN_M_TRADE_API_KEY=

# Binance COIN-M 交易 API secret：真实值不得提交；本阶段代码不会读取
BINANCE_COIN_M_TRADE_API_SECRET=

# Binance recvWindow，单位毫秒
BINANCE_RECV_WINDOW_MS=5000

# 外部请求默认超时，单位秒
EXTERNAL_REQUEST_TIMEOUT_SECONDS=10

# Binance 连接超时，单位秒
BINANCE_CONNECT_TIMEOUT_SECONDS=10

# Binance 读取超时，单位秒
BINANCE_READ_TIMEOUT_SECONDS=10

# Binance 安全读取请求最大技术尝试次数；订单提交不适用该配置
BINANCE_SAFE_READ_MAX_ATTEMPTS=2

# Binance 本地时间与交易所时间最大允许偏差，单位毫秒
BINANCE_MAX_CLOCK_SKEW_MS=1000

# Binance Account Sync 部署级硬开关：默认关闭；开启后才允许账户事实同步
BINANCE_ACCOUNT_SYNC_ENABLED=false

# Binance Account Sync 快照有效期，单位秒；交易 selector 只消费未过期 trade_preparation 快照
BINANCE_ACCOUNT_SYNC_TTL_SECONDS=1800

# Binance Account Sync 目标交易品种列表，多个 symbol 用逗号分隔
BINANCE_ACCOUNT_SYNC_SYMBOLS=BTCUSDT

# Binance Account Sync 连续失败告警阈值
BINANCE_ACCOUNT_SYNC_CONSECUTIVE_FAILURE_ALERT_THRESHOLD=3

# OpsConsole 账户刷新短期冷却秒数
BINANCE_ACCOUNT_SYNC_OPS_REFRESH_COOLDOWN_SECONDS=60

# PriceSnapshot 部署级硬开关：默认关闭；开启后才允许主动请求 mark price 并落库
PRICE_SNAPSHOT_ENABLED=false

# PriceSnapshot 业务有效期，单位秒；默认十分钟
PRICE_SNAPSHOT_TTL_SECONDS=600

# PriceSnapshot 是否写入 Redis 短期缓存；关闭或故障时回读 MySQL
PRICE_SNAPSHOT_REDIS_CACHE_ENABLED=true

# PriceSnapshot Redis 专属 key 前缀；禁止使用 latest_price 一类裸价格键
PRICE_SNAPSHOT_REDIS_KEY_PREFIX=price_snapshot

# PriceSnapshot mark price 允许的最大小数位数
PRICE_SNAPSHOT_MAX_DECIMAL_PLACES=18

# OrderPlan 部署级开关：默认关闭；开启后仍必须先通过真实交易双重权限检查
ORDER_PLAN_ENABLED=false

# OrderPlan 支持的交易市场类型；当前必须同时支持 USDS-M 和 COIN-M
ORDER_PLAN_SUPPORTED_MARKET_TYPES=usds_m_futures,coin_m_futures

# OrderPlan 目标名义仓位基准；当前固定使用包含未实现盈亏的账户权益
ORDER_PLAN_TARGET_NOTIONAL_BASIS=current_equity

# 目标名义仓位相对当前权益的最大比例；这不是交易所杠杆设置
ORDER_PLAN_MAX_TARGET_NOTIONAL_TO_EQUITY_RATIO=3.0

# 小于该名义金额的调仓正常结束，不生成候选订单意图
ORDER_PLAN_MIN_REBALANCE_NOTIONAL=20

# OrderPlan 当前仅支持 One-Way Mode
ORDER_PLAN_SUPPORTED_POSITION_MODE=one_way

# OrderPlan 当前仅生成 MARKET 候选订单意图
ORDER_PLAN_SUPPORTED_ORDER_TYPE=MARKET

# RiskCheck 部署级开关：默认关闭；开启后才允许审批 CandidateOrderIntent
RISK_CHECK_ENABLED=false

# RiskCheck 当前使用的规则集代码；生产只执行该规则集内 active + enabled 规则
RISK_CHECK_RULE_SET=p0_default

# RiskCheck 新增风险保证金安全缓冲比例；例如 0.05 表示多预留 5%
RISK_CHECK_MARGIN_BUFFER_RATIO=0.05

# RiskCheck 规则异常处理模式；当前固定 fail_closed，任何异常不得默认放行
RISK_CHECK_RULE_FAILURE_MODE=fail_closed

# ApprovedOrderIntent 有效期，单位秒；过期后不得进入执行准备
RISK_CHECK_APPROVED_INTENT_TTL_SECONDS=120

# ExecutionPreparation 部署级开关：默认关闭；开启后才允许生成 PreparedOrderIntent
EXECUTION_PREPARATION_ENABLED=false

# 执行前盘口价格相对本轮 mark price 的最大允许偏差，单位 bps；100 表示 1%
EXECUTION_PREPARATION_MAX_PRICE_DEVIATION_BPS=100

# PreparedOrderIntent 有效期，单位秒；从本次盘口价格观测时间开始计算
PREPARED_ORDER_INTENT_TTL_SECONDS=30

# ExecutionPreparation 当前支持的订单类型；当前仅允许 MARKET
EXECUTION_PREPARATION_SUPPORTED_ORDER_TYPES=MARKET

# ExecutionPreparation 当前支持的持仓模式；当前仅允许 one_way
EXECUTION_PREPARATION_SUPPORTED_POSITION_MODE=one_way

# OrderStatusSync 部署级开关：默认关闭；只允许查询既有 OrderSubmissionAttempt 的交易所状态
ORDER_STATUS_SYNC_ENABLED=false

# OrderStatusSync 立即轮询间隔，单位秒；默认每 2 秒查一次
ORDER_STATUS_POLL_INTERVAL_SECONDS=2

# OrderStatusSync 立即轮询最长持续时间，单位秒；默认最多 30 秒
ORDER_STATUS_POLL_MAX_DURATION_SECONDS=30

# OrderStatusSync 受控人工恢复窗口，单位秒；入口由 OpsConsole 需求定义
ORDER_STATUS_RECOVERY_WINDOW_SECONDS=86400

# FillSync 部署级开关：默认关闭；开启后才允许根据终态订单状态查询并落库成交事实
FILL_SYNC_ENABLED=false

# FillSync 单页成交查询数量
FILL_SYNC_PAGE_SIZE=100

# FillSync 单次同步最多查询页数
FILL_SYNC_MAX_PAGES=10

# FillSync 受控恢复窗口，单位秒；入口由 OpsConsole 需求定义
FILL_SYNC_RECOVERY_WINDOW_SECONDS=86400

# 兼容旧底座配置：安全读取请求最大技术重试次数；订单提交不适用该配置
SAFE_READ_MAX_TECHNICAL_RETRIES=2

# DeepSeek base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek API key：真实值不得提交
DEEPSEEK_API_KEY=

# DeepSeek 默认模型套餐编号
DEEPSEEK_DEFAULT_MODEL_PROFILE=default_review

# Hermes Webhook URL：真实值不得提交
HERMES_WEBHOOK_URL=

# Hermes Webhook secret：真实值不得提交
HERMES_WEBHOOK_SECRET=

# 是否允许外部通知投递；关闭时仍必须保存 AlertEvent
NOTIFICATIONS_DELIVERY_ENABLED=false

# 通知默认通道
NOTIFICATIONS_DEFAULT_CHANNEL=console_only
